# Neon Postgres connection strings — see CLAUDE.md "Backend + database
# foundation" for how to create a Neon project and where to find these.
#
# Copy this file to .env.local and fill in real values from your own Neon
# project dashboard. Never commit .env.local or any real credentials —
# .env.local is already gitignored (see .gitignore's `.env*` pattern).

# The pooled connection string. Used by the application at request time
# (src/db/index.ts).
DATABASE_URL=

# The direct (unpooled) connection string. Used by Drizzle Kit for
# migrations (drizzle.config.ts) — some migration tooling behaves better
# against a direct connection than through a pooler.
DATABASE_URL_UNPOOLED=

# Admin authentication (Auth.js v5, Google OAuth only, JWT session
# strategy) — see CLAUDE.md "Admin foundation" for how to create the
# Google OAuth credentials and generate a secret. Server-only; never
# prefix any of these with NEXT_PUBLIC_.

# Session signing/encryption secret. Generate with `openssl rand -base64 32`,
# or node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# — never hardcode or commit a real value. (`npx auth secret` is suggested by
# Auth.js's own docs, but in this environment it resolved to an unrelated
# package printing a BETTER_AUTH_SECRET-named suggestion — see CLAUDE.md
# "Admin foundation" for the full note. Verify what it prints before trusting it.)
AUTH_SECRET=

# From a Google Cloud OAuth 2.0 Client ID (Web application type).
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Media Library (Phase 15) — Vercel Blob, authenticated via Vercel's OIDC
# federation, NOT a long-lived BLOB_READ_WRITE_TOKEN. @vercel/blob (2.x)
# auto-detects both of these from the environment; nothing in the app code
# references them by name directly.
#
# Both are populated automatically by `vercel env pull` once a Blob store
# is linked to this project (Vercel dashboard -> Storage -> your store ->
# Connect Project, or `vercel link` first if the project isn't linked yet).
# Never commit real values; never prefix either with NEXT_PUBLIC_.

# Short-lived OIDC identity token — expires and must be refreshed locally
# by re-running `vercel env pull` (or restarting `vercel dev`) periodically
# during local development. This is expected, not an error.
VERCEL_OIDC_TOKEN=

# The target Blob store's stable ID (format: store_xxxxxxxxxxxx). Unlike
# VERCEL_OIDC_TOKEN this does not expire — find it in the Vercel dashboard
# under Storage -> your Blob store -> Settings if `vercel env pull` doesn't
# populate it.
BLOB_STORE_ID=

# Legacy/alternative auth path — a long-lived read-write token scoped to
# one store. Not required when VERCEL_OIDC_TOKEN + BLOB_STORE_ID are both
# set; @vercel/blob only falls back to this if OIDC auth isn't available.
# Leave unset under the OIDC flow.
# BLOB_READ_WRITE_TOKEN=
